<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Table</title>
  <style>
    table {
      border-collapse: collapse; /* borders collapse into one */
      width: 300px;
    }
    table, th, td {
      border: 1px solid black;
    }
    th, td {
      padding: 5px;              /* th, td padding 5px */
      text-align: left;          /* text aligns to left */
    }
  </style>
</head>
<body>

<table>
  <tr>
    <th>Name</th>
    <th>Student ID</th>
  </tr>
  <tr>
    <td>周怡辰</td>
    <td>112401541</td>
  </tr>
</table>

</body>
</html>
